{
  "name": "resilient-ts",
  "version": "0.1.0",
  "description": "Production-grade configurable retry and resilience toolkit for TypeScript and Node.js",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "dev": "tsup src/index.ts --watch",
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "retry",
    "typescript",
    "backoff",
    "resilience",
    "circuit-breaker",
    "nodejs"
  ],
  "author": "Debshankar Dey",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsup": "^8.5.1",
    "typescript": "5.9",
    "vitest": "^4.1.5"
  }
}
