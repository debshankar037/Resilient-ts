{
  "name": "resilient-ts",
  "version": "0.1.6",
  "description": "Production-grade configurable retry and resilience toolkit for TypeScript and Node.js",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "dev": "tsup src/index.ts --watch",
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "test": "vitest run",
    "prepublishOnly": "npm run build",
    "chaos:server": "tsx tests/chaos/flaky-server.ts",
    "chaos:test": "vitest tests/chaos"
  },
  "keywords": [
    "retry",
    "typescript",
    "backoff",
    "resilience",
    "circuit-breaker",
    "nodejs"
  ],
  "author": "Debshankar Dey",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "express": "^5.2.1",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "5.9",
    "vitest": "^4.1.5"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/debshankar037/Resilient-ts"
  },
  "homepage": "https://github.com/debshankar037/Resilient-ts"
}